<Window
    x:Class="WinTrayApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="WinTrayApp">
  <Grid Margin="12">
    <StackPanel>
      <TextBlock FontSize="18" Text="Items" Margin="0,0,0,8" />
      <ListBox x:Name="ItemsList" />
      <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
        <Button x:Name="AddButton" Content="Add Item" Width="100" Margin="0,0,8,0" />
        <Button x:Name="RemoveButton" Content="Remove Selected" Width="140" />
      </StackPanel>
    </StackPanel>
  </Grid>
</Window>
